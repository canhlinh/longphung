# Local PostgreSQL (docker compose)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/long_phung

# Vercel/Neon — set automatically when you add Neon integration on Vercel
# POSTGRES_URL=postgres://...
# (App accepts DATABASE_URL or POSTGRES_URL)

# Bắt buộc trên Vercel (cả lúc build — payload migrate cần biến này)
PAYLOAD_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MinIO / S3-compatible storage (production + local docker compose)
S3_ENDPOINT=http://127.0.0.1:9000
S3_PUBLIC_URL=http://127.0.0.1:9000
S3_BUCKET=longphung-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1

ADMIN_EMAIL=admin@minhkien.local
ADMIN_PASSWORD=MinhKien123!
